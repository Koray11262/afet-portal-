                    <ul class="medsApp__list" data-meds-list aria-live="polite"></ul>
                    <div class="medsApp__actions">
                      <button type="button" class="btn btn--ghost btn--sm" data-meds-action="print">Listeyi yazdır</button>
                      <button type="button" class="btn btn--ghost btn--sm" data-meds-action="clear">Tümünü sil</button>
                    </div>
                    <p class="muted small medsApp__note">Bilgiler yalnızca bu cihazda saklanır. Acil çantanıza yazılı bir kopya da koymanız önerilir.</p>
                  </div>
                </div>
              </div>
            </article>

            <article class="panel awarenessCard awarenessCard--full seniorCard">
              <div class="seniorCard__split">
                <div class="seniorCard__body">
                  <h4>Sağlık Belgeleri</h4>
                  <p class="muted">
                    Kimlik, sağlık raporları ve reçetelerin kopyaları su geçirmez dosyalarda saklanmalıdır.
                  </p>
                </div>
                <div class="seniorCard__media">
                  <img
                    class="mediaZoom"
                    src="/assets/senior/saglik-belgeleri.png"
                    alt="Aile ve doktor ile sağlık belgeleri kontrol listesi illüstrasyonu"
                    loading="lazy"
                    width="480"
                    height="360"
                    tabindex="0"
                    role="button"
                    aria-label="Sağlık belgeleri görselini büyüt"
                  />
                </div>
              </div>
            </article>

            <article class="panel awarenessCard awarenessCard--full seniorCard">
              <h3 class="seniorCard__series">Video rehberler</h3>
              <p class="muted" style="margin:0 0 14px">Afet hazırlığı ve güvenli davranışlar hakkında kısa videolar.</p>
              <div class="seniorVideoGrid" aria-label="YouTube video rehberleri">
                <button type="button" class="seniorVideoCard" data-youtube-id="S1PEUG4Sj64" aria-label="YouTube videosunu oynat">
                  <span class="seniorVideoCard__thumb">
                    <img
                      src="https://i.ytimg.com/vi/S1PEUG4Sj64/hqdefault.jpg"
                      alt=""
                      loading="lazy"
                      width="480"
                      height="360"
                    />
                    <span class="seniorVideoCard__play" aria-hidden="true"></span>
                  </span>
                  <span class="seniorVideoCard__title" data-yt-title="S1PEUG4Sj64">Video yükleniyor…</span>
                </button>
                <button type="button" class="seniorVideoCard" data-youtube-id="K0keerAalYE" aria-label="YouTube videosunu oynat">
                  <span class="seniorVideoCard__thumb">
                    <img
                      src="https://i.ytimg.com/vi/K0keerAalYE/hqdefault.jpg"
                      alt=""
                      loading="lazy"
                      width="480"
                      height="360"
                    />
                    <span class="seniorVideoCard__play" aria-hidden="true"></span>
                  </span>
                  <span class="seniorVideoCard__title" data-yt-title="K0keerAalYE">Video yükleniyor…</span>
                </button>
              </div>
            </article>

            <article class="panel awarenessCard awarenessCard--full seniorCard">
              <h3 class="seniorCard__series">Ev güvenlik kontrol listesi</h3>
              <p class="muted" style="margin:0 0 14px">
                Evinizi madde madde kontrol edin. Eksikler için öneri alın; tekrar kontrol ettiğinizde önceki cevaplarınızla karşılaştırılarak hatırlatma ve gerileme uyarıları gösterilir.
              </p>
              <div class="homeCheck" data-home-check>
                <div class="homeCheck__top">
                  <span class="muted small" data-home-check-meta>10 madde · işaretleyip değerlendirin</span>
                  <div class="homeCheck__bar" aria-hidden="true">
                    <div class="homeCheck__barFill" data-home-check-bar style="width:0%"></div>
                  </div>
                </div>
                <div class="homeCheck__list" data-home-check-list role="group" aria-label="Ev güvenlik kontrol maddeleri"></div>
                <div class="homeCheck__actions">
                  <button type="button" class="btn btn--primary btn--sm" data-home-check-action="evaluate">Değerlendir</button>
                  <button type="button" class="btn btn--ghost btn--sm" data-home-check-action="reset">Tümünü temizle</button>
                </div>
                <div class="homeCheck__results" data-home-check-results hidden aria-live="polite"></div>
              </div>
            </article>
          </div>

          <div class="panel awarenessRefs">
            <h3>Güvenilir içerik kaynakları (40+ / sağlık)</h3>
            <ul class="refList" id="refSeniors"></ul>
          </div>
        </section>

        <dialog class="youtubeModal" id="youtubeModal">
          <form method="dialog" class="youtubeModal__panel">
            <div class="youtubeModal__head">
              <h3 id="youtubeModalTitle">Video</h3>
              <button class="btn btn--ghost btn--sm" value="close" aria-label="Kapat">Kapat</button>
            </div>
            <div class="youtubeModal__body">
              <iframe
                id="youtubeModalIframe"
                class="youtubeModal__iframe"
                title="YouTube video oynatıcı"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
            <div class="youtubeModal__foot">
              <a id="youtubeModalOpen" class="btn btn--ghost btn--sm" href="#" target="_blank" rel="noopener noreferrer">YouTube'da aç</a>
            </div>
          </form>
        </dialog>

        <dialog class="coloringModal" id="coloringModal">
          <form method="dialog" class="coloringModal__panel">
            <div class="coloringModal__head">
              <h3 id="coloringModalTitle">Boyama</h3>
              <button class="btn btn--ghost btn--sm" value="close" aria-label="Kapat">Kapat</button>
            </div>
            <div id="coloringModalHost" class="coloringModal__host"></div>
          </form>
        </dialog>

        <dialog class="kidsAnimModal" id="kidsAnimModal">
          <form method="dialog" class="kidsAnimModal__panel">
            <div class="kidsAnimModal__head">
              <h3 id="kidsAnimModalTitle">Animasyon</h3>
              <button class="btn btn--ghost btn--sm" value="close" aria-label="Kapat">Kapat</button>
            </div>
            <div id="kidsAnimModalHost" class="kidsAnimModal__host"></div>
          </form>
        </dialog>

        <dialog class="mediaModal" id="mediaModal">
          <form method="dialog" class="mediaModal__panel">
            <div class="mediaModal__head">
              <h3 id="mediaModalTitle">Görsel</h3>
              <button class="btn btn--ghost btn--sm" value="close" aria-label="Kapat">Kapat</button>
            </div>
            <div class="mediaModal__body">
              <img id="mediaModalImg" class="mediaModal__img" alt="" />
            </div>
            <div class="mediaModal__foot">
              <a id="mediaModalOpen" class="btn btn--primary btn--sm" href="#" target="_blank" rel="noopener noreferrer">Yeni sekmede aç</a>
            </div>
          </form>
        </dialog>
      </div>
    `,
  })
%>

