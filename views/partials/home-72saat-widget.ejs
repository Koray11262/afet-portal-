<div class="saat72FabWrap" id="saat72Widget">
  <button
    type="button"
    class="saat72Fab"
    id="saat72FabBtn"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="saat72Modal"
    title="Afet sonrası ilk 72 saat simülatörü"
  >
    <span class="saat72Fab__icon" aria-hidden="true">
      <svg viewBox="0 0 64 64" focusable="false">
        <circle cx="32" cy="32" r="28" fill="#7c3aed" opacity="0.12"/>
        <circle cx="32" cy="32" r="22" fill="none" stroke="#7c3aed" stroke-width="3"/>
        <line x1="32" y1="32" x2="32" y2="18" stroke="#7c3aed" stroke-width="3" stroke-linecap="round"/>
        <line x1="32" y1="32" x2="42" y2="36" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round"/>
        <text x="32" y="54" text-anchor="middle" font-size="9" font-weight="800" fill="#5b21b6">72s</text>
      </svg>
    </span>
    <span class="saat72Fab__label">72 Saat</span>
  </button>
</div>

<div class="saat72Modal" id="saat72Modal" hidden role="dialog" aria-modal="true" aria-labelledby="saat72ModalTitle">
  <div class="saat72Modal__backdrop" data-saat72-close></div>
  <div class="saat72Modal__panel">
    <header class="saat72Modal__head">
      <div>
        <h2 class="saat72Modal__title" id="saat72ModalTitle">Afet Sonrası İlk 72 Saat</h2>
        <p class="muted saat72Modal__meta" id="saat72ModalMeta">Karakterinize göre farklı senaryolar yaşayacaksınız.</p>
      </div>
      <button type="button" class="saat72Modal__close" data-saat72-close aria-label="Kapat">×</button>
    </header>

    <div class="saat72Modal__body" id="saat72Body">
      <section class="saat72Setup" id="saat72Setup">
        <p class="muted saat72Setup__lead">
          Gerçek bir afet değil; eğitim amaçlı simülasyondur. Acil çanta ve aile planı verileriniz sonuçlara yansır.
        </p>
        <div class="saat72PrepHint" id="saat72PrepHint"></div>
        <div class="saat72CharacterPreview" id="saat72CharacterPreview" hidden></div>
        <form class="saat72SetupForm" id="saat72SetupForm">
          <label class="saat72Field">
            <span class="muted">Afet türü</span>
            <select id="saat72Disaster" name="disaster" required></select>
          </label>
          <label class="saat72Field">
            <span class="muted">Karakter</span>
            <select id="saat72Character" name="character" required></select>
          </label>
          <label class="saat72Field">
            <span class="muted">Yaşadığınız ortam</span>
            <select id="saat72Environment" name="environment" required></select>
          </label>
          <button type="submit" class="btn btn--primary">Simülasyonu Başlat</button>
        </form>
      </section>

      <section class="saat72Play" id="saat72Play" hidden>
        <div class="saat72Timeline" id="saat72Timeline" aria-label="Zaman dilimleri"></div>
        <div class="saat72Event" id="saat72Event"></div>
        <div class="saat72Question" id="saat72Question"></div>
        <div class="saat72Options" id="saat72Options"></div>
        <div class="saat72Feedback" id="saat72Feedback" hidden></div>
        <div class="saat72PrepNotes" id="saat72PrepNotes" hidden></div>
        <div class="saat72PlayActions" id="saat72PlayActions" hidden>
          <button type="button" class="btn btn--primary" id="saat72NextBtn">Sonraki adım</button>
        </div>
      </section>

      <section class="saat72Result" id="saat72Result" hidden>
        <div class="saat72Result__score" id="saat72ResultScore"></div>
        <div class="saat72Result__summary" id="saat72ResultSummary"></div>
        <div class="saat72Result__prep" id="saat72ResultPrep"></div>
        <div class="saat72Result__actions">
          <button type="button" class="btn btn--primary" id="saat72RestartBtn">Yeniden oyna</button>
          <a class="btn btn--ghost" href="/acil-canta">Acil çanta</a>
          <a class="btn btn--ghost" href="/aile-afet-plani">Aile planı</a>
        </div>
      </section>
    </div>
  </div>
</div>
