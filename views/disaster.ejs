<%- 
  include("layout", {
    pageTitle,
    nav,
    pageHero,
    extraScripts:
      disaster.content?.beforeActions?.length
        ? `<script src="/disaster-prep-actions.js"></script>`
        : undefined,
    body: `
      <div class="grid">
        <section class="panel">
          <h2>Hızlı Özet</h2>
          ${
            disaster.content?.summaryBlocks?.length
              ? disaster.content.summaryBlocks
                  .map((b) => {
                    if (b.type === "p") return `<p>${b.text || ""}</p>`;
                    if (b.type === "list")
                      return `
                        <div class="subsection">
                          ${b.title ? `<h3>${b.title}</h3>` : ``}
                          ${
                            b.bullets?.length
                              ? `<ul>${b.bullets.map((x) => `<li>${x}</li>`).join("")}</ul>`
                              : ``
                          }
                        </div>
                      `;
                    return ``;
                  })
                  .join("")
              : `
                ${
                  disaster.content?.summaryParagraphs?.length
                    ? disaster.content.summaryParagraphs.map((p) => `<p>${p}</p>`).join("")
                    : `<p class="muted">İçerik eklenecek (halk için kısa açıklama).</p>`
                }
                ${
                  disaster.content?.summaryLists?.length
                    ? disaster.content.summaryLists
                        .map(
                          (l) => `
                            <div class="subsection">
                              ${l.title ? `<h3>${l.title}</h3>` : ``}
                              ${
                                l.bullets?.length
                                  ? `<ul>${l.bullets.map((x) => `<li>${x}</li>`).join("")}</ul>`
                                  : ``
                              }
                            </div>
                          `
                        )
                        .join("")
                    : ``
                }
              `
          }
        </section>

        ${
          disaster.content?.hidePanels?.map
            ? ``
            : `
              <section class="panel">
                <h2>Türkiye’de Riskli Bölgeler (Harita)</h2>
                ${
                  disaster.slug === "deprem"
                    ? `
                      <div
                        class="leafletMap leafletMap--compact disasterMap"
                        id="disasterMap-deprem"
                        data-mode="choropleth"
                        data-risk="/api/risk/deprem"
                        data-geojson="/turkey.geojson"
                        data-title="Deprem riski"
                      ></div>
                      <div class="mapLegend">
                        <span class="badge badge--high">Yüksek</span>
                        <span class="badge badge--mid">Orta</span>
                        <span class="badge badge--low">Düşük</span>
                      </div>
                    `
                    : disaster.slug === "heyelan"
                      ? `
                        <div
                          class="leafletMap leafletMap--compact disasterMap"
                          id="disasterMap-heyelan"
                          data-mode="choropleth"
                          data-risk="/api/risk/heyelan"
                          data-geojson="/turkey.geojson"
                          data-title="Heyelan riski"
                        ></div>
                        <div class="mapLegend">
                          <span class="badge badge--high">Yüksek</span>
                          <span class="badge badge--mid">Orta</span>
                          <span class="badge badge--low">Düşük</span>
                        </div>
                      `
                      : disaster.slug === "sel-taskin"
                        ? `
                          <div
                            class="leafletMap leafletMap--compact disasterMap"
                            id="disasterMap-sel"
                            data-mode="choropleth"
                            data-risk="/api/risk/sel"
                            data-geojson="/turkey.geojson"
                            data-title="Sel / Taşkın riski"
                          ></div>
                          <div class="mapLegend">
                            <span class="badge badge--high">Yüksek</span>
                            <span class="badge badge--mid">Orta</span>
                            <span class="badge badge--low">Düşük</span>
                          </div>
                        `
                        : disaster.slug === "cig"
                          ? `
                            <div
                              class="leafletMap leafletMap--compact disasterMap"
                              id="disasterMap-cig"
                              data-mode="choropleth"
                              data-risk="/api/risk/cig"
                              data-geojson="/turkey.geojson"
                              data-title="Çığ riski"
                            ></div>
                            <div class="mapLegend">
                              <span class="badge badge--high">Yüksek</span>
                              <span class="badge badge--mid">Orta</span>
                              <span class="badge badge--low">Düşük</span>
                            </div>
                          `
                          : disaster.slug === "kuraklik"
                            ? `
                              <div
                                class="leafletMap leafletMap--compact disasterMap"
                                id="disasterMap-kuraklik"
                                data-mode="choropleth"
                                data-risk="/api/risk/kuraklik"
                                data-geojson="/turkey.geojson"
                                data-title="Kuraklık riski"
                              ></div>
                              <div class="mapLegend">
                                <span class="badge badge--high">Yüksek</span>
                                <span class="badge badge--mid">Orta</span>
                                <span class="badge badge--low">Düşük</span>
                              </div>
                            `
                            : disaster.slug === "orman-yangini"
                              ? `
                                <div
                                  class="leafletMap leafletMap--compact disasterMap"
                                  id="disasterMap-yangin"
                                  data-mode="choropleth"
                                  data-risk="/api/risk/yangin"
                                  data-geojson="/turkey.geojson"
                                  data-title="Orman yangını riski"
                                ></div>
                                <div class="mapLegend">
                                  <span class="badge badge--high">Yüksek</span>
                                  <span class="badge badge--mid">Orta</span>
                                  <span class="badge badge--low">Düşük</span>
                                </div>
                              `
                    : `
                      <p class="muted">Bu bölümde risk bölgelerini harita üzerinde göstereceğiz (sonraki adım).</p>
                      <div class="mapPlaceholder">Harita alanı (Leaflet) — daha sonra eklenecek</div>
                    `
                }
              </section>
            `
        }
      </div>

      ${
        disaster.content?.hideSections?.before
          ? ``
          : `
            <section class="panel disasterSection">
              <h2>Öncesinde Ne Yapmalı?</h2>
              <div class="disasterSection__split${disaster.content?.beforeImages?.length ? "" : " disasterSection__split--textOnly"}">
                <div class="disasterSection__text">
                  ${
                    disaster.content?.beforeIntro
                      ? `<p>${disaster.content.beforeIntro}</p>`
                      : ``
                  }
                  ${
                    disaster.content?.beforeSections?.length
                      ? disaster.content.beforeSections
                          .map((s) => {
                            const paras = (s.paragraphs || [])
                              .map((p) => `<p class="subsection__p">${p}</p>`)
                              .join("");
                            const list = (s.bullets || []).length
                              ? `<ul>${s.bullets.map((b) => `<li>${b}</li>`).join("")}</ul>`
                              : "";
                            return `
                              <div class="subsection">
                                <h3>${s.title}</h3>
                                ${paras}
                                ${list}
                              </div>
                            `;
                          })
                          .join("")
                      : !disaster.content?.beforeIntro
                        ? `<p class="muted">İçerik eklenecek.</p>`
                        : ``
                  }
                  ${
                    disaster.content?.beforeActions?.length
                      ? `
                    <nav class="disasterPrepActions" aria-label="Hazırlık araçları">
                      <h3 class="disasterPrepActions__title">Hazırlığınızı tamamlayın</h3>
                      <ul class="disasterPrepActions__list">
                        ${disaster.content.beforeActions
                          .map(
                            (a) => `
                          <li class="disasterPrepActions__item">
                            <a
                              class="disasterPrepActions__link"
                              href="${a.href}"
                              ${a.dynamicIl ? `data-dynamic-il-risk="1"` : ""}
                              ${a.related ? `data-related-section="${a.related}"` : ""}
                            >${a.label} →</a>
                          </li>`
                          )
                          .join("")}
                      </ul>
                    </nav>
                  `
                      : ``
                  }
                </div>
                ${
                  disaster.content?.beforeImages?.length
                    ? `<div class="disasterMediaStack" aria-label="Öncesinde görseller">
                        ${disaster.content.beforeImages
                          .map(
                            (img) => `
                          <figure class="disasterMediaStack__item">
                            <img src="${img.src}" alt="${img.alt || ""}" loading="lazy" class="disasterMediaStack__img" />
                            ${img.caption ? `<figcaption class="disasterMediaStack__cap muted small">${img.caption}</figcaption>` : ""}
                          </figure>`
                          )
                          .join("")}
                      </div>`
                    : ``
                }
              </div>
            </section>
          `
      }

      ${
        disaster.content?.hideSections?.during
          ? ``
          : `
            <section class="panel disasterSection">
              <h2>Sırasında Ne Yapmalı?</h2>
              <div class="disasterSection__split${disaster.content?.duringImages?.length ? "" : " disasterSection__split--textOnly"}">
                <div class="disasterSection__text">
                  ${
                    disaster.content?.duringIntro
                      ? `<p>${disaster.content.duringIntro}</p>`
                      : ``
                  }
                  ${
                    disaster.content?.duringSections?.length
                      ? disaster.content.duringSections
                          .map((s) => {
                            const paras = (s.paragraphs || [])
                              .map((p) => `<p class="subsection__p">${p}</p>`)
                              .join("");
                            const list = (s.bullets || []).length
                              ? `<ul>${s.bullets.map((b) => `<li>${b}</li>`).join("")}</ul>`
                              : "";
                            return `
                              <div class="subsection">
                                <h3>${s.title}</h3>
                                ${paras}
                                ${list}
                              </div>
                            `;
                          })
                          .join("")
                      : !disaster.content?.duringIntro
                        ? `<p class="muted">İçerik eklenecek.</p>`
                        : ``
                  }
                </div>
                ${
                  disaster.content?.duringImages?.length
                    ? `<div class="disasterMediaStack" aria-label="Sırasında görseller">
                        ${disaster.content.duringImages
                          .map(
                            (img) => `
                          <figure class="disasterMediaStack__item">
                            <img src="${img.src}" alt="${img.alt || ""}" loading="lazy" class="disasterMediaStack__img" />
                            ${img.caption ? `<figcaption class="disasterMediaStack__cap muted small">${img.caption}</figcaption>` : ""}
                          </figure>`
                          )
                          .join("")}
                      </div>`
                    : ``
                }
              </div>
            </section>
          `
      }

      ${
        disaster.content?.hideSections?.after
          ? ``
          : `
            <section class="panel disasterSection">
              <h2>Sonrasında Ne Yapmalı?</h2>
              <div class="disasterSection__split${disaster.content?.afterImages?.length ? "" : " disasterSection__split--textOnly"}">
                <div class="disasterSection__text">
                  ${
                    disaster.content?.afterIntro
                      ? `<p>${disaster.content.afterIntro}</p>`
                      : ``
                  }
                  ${
                    disaster.content?.afterSections?.length
                      ? disaster.content.afterSections
                          .map((s) => {
                            const paras = (s.paragraphs || [])
                              .map((p) => `<p class="subsection__p">${p}</p>`)
                              .join("");
                            const list = (s.bullets || []).length
                              ? `<ul>${s.bullets.map((b) => `<li>${b}</li>`).join("")}</ul>`
                              : "";
                            return `
                              <div class="subsection">
                                <h3>${s.title}</h3>
                                ${paras}
                                ${list}
                              </div>
                            `;
                          })
                          .join("")
                      : !disaster.content?.afterIntro
                        ? `<p class="muted">İçerik eklenecek.</p>`
                        : ``
                  }
                </div>
                ${
                  disaster.content?.afterImages?.length
                    ? `<div class="disasterMediaStack" aria-label="Sonrasında görseller">
                        ${disaster.content.afterImages
                          .map(
                            (img) => `
                          <figure class="disasterMediaStack__item">
                            <img src="${img.src}" alt="${img.alt || ""}" loading="lazy" class="disasterMediaStack__img" />
                            ${img.caption ? `<figcaption class="disasterMediaStack__cap muted small">${img.caption}</figcaption>` : ""}
                          </figure>`
                          )
                          .join("")}
                      </div>`
                    : ``
                }
              </div>
            </section>
          `
      }

      ${
        disaster.content?.footerVideo
          ? `
            <section class="panel disasterVideo">
              <h2>Video</h2>
              <p class="muted">${disaster.content.footerVideo.title || "İzle"}</p>
              <a
                class="disasterVideoCard"
                href="${disaster.content.footerVideo.href}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="${disaster.content.footerVideo.title || "YouTube videosunu aç"}"
              >
                <span class="disasterVideoCard__thumb">
                  <img
                    src="https://i.ytimg.com/vi/${disaster.content.footerVideo.youtubeId}/hqdefault.jpg"
                    alt=""
                    loading="lazy"
                    width="480"
                    height="360"
                  />
                  <span class="disasterVideoCard__play" aria-hidden="true"></span>
                </span>
                <span class="disasterVideoCard__title">${disaster.content.footerVideo.title || "YouTube'da izle"}</span>
              </a>
            </section>
          `
          : ``
      }
    `,
  })
%>

